            <p>Trending</p>
        </div>
        <!-- Rooms icon -->
        <div class="filter">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </div>
        <!-- Mountain City icon -->
        <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Mountain City</p>
        </div>
        <!-- Farms icon -->
        <div class="filter">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </div>
        <!-- Beach icon -->
        <div class="filter">
            <div><i class="fa-solid fa-umbrella-beach"></i></div>
            <p>Beach</p>
        </div>
        <!-- arctic icon -->
        <div class="filter">
            <div><i class="fa-regular fa-snowflake"></i></div>
            <p>Arctic Land</p>
        </div>
        <!-- Castles icon -->
        <div class="filter">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </div>
        <!-- swimming icon -->
        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i></i></div>
            <p>swimming</p>
        </div>
        <!-- Dome icon -->
        <div class="filter">
            <div><i class="fa-solid fa-landmark-dome"></i></div>
            <p>Dome</p>
        </div>
        <!-- skiing icon -->
        <div class="filter">
            <div><i class="fa-solid fa-person-skiing"></i></div>
            <p>Skiing</p>
        </div>
        <!-- Museum icon -->
        <div class="filter">
            <div><i class="fa-solid fa-building-columns"></i></div>
            <p>Museum</p>
        </div>  
        <!-- Sailing icon -->
        <div class="filter">
            <div><i class="fa-solid fa-sailboat"></i></div>
            <p>Sailing</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-tent"></i></div>
            <p>Camping</p>
        </div>
        <div class="tax-switch">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>

<section class="stay-grid">
    <% for(let listing of allListing) { 
        const reviewArray = Array.isArray(listing.reviews) ? listing.reviews : [];
        const reviewCount = reviewArray.length;
        const ratingTotal = reviewArray.reduce((sum , review) => sum + (review.rating || 0) , 0);
        const avgRatingValue = reviewCount ? ratingTotal / reviewCount : null;
        const displayRating = avgRatingValue ? avgRatingValue.toFixed(2) : null;
        const badgeText = avgRatingValue && avgRatingValue >= 4.5 && reviewCount >= 3 ? "Guest favourite" : null;
        const locationLabel = listing.location || "";
        const countryLabel = listing.country || "";
    %>
        <a href="/listings/<%= listing._id %>" class="stay-card linking-link">
            <div class="stay-card__media">
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                <% if(badgeText) { %>
                    <span class="stay-card__badge"><%= badgeText %></span>
                <% } %>
                <span class="stay-card__wishlist" aria-hidden="true">
                    <i class="fa-regular fa-heart"></i>
                </span>
            </div>
            <div class="stay-card__body">
                <div class="stay-card__title-row">
                    <p class="stay-card__title"><%= listing.title %></p>
                    <div class="stay-card__rating">
                        <i class="fa-solid fa-star"></i>
                        <span><%= displayRating ? displayRating : "New" %></span>
                    </div>
                </div>
                <% if(locationLabel || countryLabel) { %>
                    <p class="stay-card__meta">
                        <%= locationLabel %><%= locationLabel && countryLabel ? ", " : "" %><%= countryLabel %>
                    </p>
                <% } else { %>
                    <p class="stay-card__meta">India</p>
                <% } %>
                <p class="stay-card__price">
                    &#8377; <%= listing.price.toLocaleString("en-IN") %>
                    <span>night</span>
                    <i class="tax-info">+18% GST</i>
                </p>
                <p class="stay-card__subtext">
                    <% if(reviewCount) { %>
                        <%= reviewCount %> review<%= reviewCount > 1 ? "s" : "" %>
                    <% } else { %>
                        Be the first to review
                    <% } %>
                </p>
            </div>
        </a>
    <% } %>
</section>

<script>
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");
    taxSwitch.addEventListener("click" , () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for(tax of taxInfo) {
            if(tax.style.display != "inline")  {
                tax.style.display = "inline";
            } else { 
                tax.style.display = "none";
            }
        }
        console.log(tax.style.display);
    })
</script>