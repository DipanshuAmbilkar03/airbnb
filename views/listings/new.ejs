<% layout("/layouts/boilerplate") %>

<section class="form-shell">
    <div class="form-heading">
        <p class="eyebrow">Host on WanderLust</p>
        <h1>Create a listing</h1>
    </div>

    <form method="POST" action="/listings" novalidate class="needs-validation listing-form" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input id="title" name="listing[title]" placeholder="Beach house near Candolim" type="text" class="form-control" minlength="3" maxlength="120" required>
            <div class="invalid-feedback">Please enter a title.</div>
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea id="description" name="listing[description]" placeholder="Describe the stay, neighborhood, and what guests will love." class="form-control" rows="5" minlength="20" maxlength="2000" required></textarea>
            <div class="invalid-feedback">Please add a description with at least 20 characters.</div>
        </div>
        
        <div class="mb-3">
            <label for="image" class="form-label">Upload image</label>
            <input id="image" name="listing[image]" class="form-control" type="file" accept="image/png,image/jpeg,image/webp">
            <div class="form-text">JPEG, PNG, or WEBP. Maximum 5 MB.</div>
        </div>
        
        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price per night</label>
                <input id="price" name="listing[price]" placeholder="12000" class="form-control" type="number" min="0" max="10000000" required>
                <div class="invalid-feedback">Please enter a valid price.</div>
            </div>

            <div class="mb-3 col-md-8">
                <label for="country" class="form-label">Country</label>
                <input id="country" name="listing[country]" placeholder="India" class="form-control" type="text" minlength="2" maxlength="120" required>
                <div class="invalid-feedback">Please enter the country.</div>
            </div>                     
        </div>

        <div class="mb-4">
            <label for="location" class="form-label">Location</label>
            <input id="location" name="listing[location]" placeholder="Calangute, Goa" class="form-control" type="text" minlength="2" maxlength="120" required>
            <div class="invalid-feedback">Please enter a location.</div>
        </div>

        <button class="btn btn-dark" type="submit">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span>Publish listing</span>
        </button>
    </form>
</section>
